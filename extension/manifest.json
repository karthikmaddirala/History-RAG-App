{
  "manifest_version": 3,
  "name": "History RAG",
  "version": "0.1.0",
  "description": "Chat with your browsing history.",
  "permissions": ["history", "storage", "sidePanel"],
  "host_permissions": ["http://localhost:8000/*"],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "action": { "default_title": "Open History RAG" }
}
